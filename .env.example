# === 系統配置 ===
NODE_ENV=development

# === 資料庫配置 (PostgreSQL) ===
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=chatpassword
POSTGRES_DB=chatdb
DATABASE_URL=postgresql://chatuser:chatpassword@db:5432/chatdb

# === 後端配置 ===
PORT=4000
JWT_SECRET=dev_secret_key
JWT_EXPIRES_IN=15m
# 關閉速率限制（開發 / 測試用，正式環境請移除）
RATE_LIMIT_DISABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3005

# === 前端配置 ===
# Next.js 前端呼叫後端位址
# Browser-facing backend URL. Docker Compose exposes backend host port 4005.
NEXT_PUBLIC_API_URL=http://localhost:4005
# 允許進行開發連線的來源網域（例如使用 Tailscale 連線時填入：raynb.tail5fc9fe.ts.net,100.73.193.72）
ALLOWED_DEV_ORIGINS=
# 訊息最大字數限制（預設為 1000）
NEXT_PUBLIC_MAX_MESSAGE_LENGTH=1000

# Docker Compose upload storage source
# Default: Docker named volume `app_uploads`
# Example host path on Windows: C:/chat-uploads
# Example host path on macOS/Linux: /Users/you/chat-uploads
UPLOADS_MOUNT_SOURCE=app_uploads

# Attachment upload configuration
# By default attachment type restriction is disabled, so uploads stay type-open.
ATTACHMENT_TYPE_RESTRICTION_ENABLED=false
# Built-in reference whitelist. These values only take effect when
# ATTACHMENT_TYPE_RESTRICTION_ENABLED=true, and can be overridden per deployment.
ATTACHMENT_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/zip,text/plain
ATTACHMENT_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf,.zip,.txt
# 10 MB default
ATTACHMENT_MAX_BYTES=10485760
# === 部署配置 ===
# Cloudflare Tunnel Token
TUNNEL_TOKEN=
